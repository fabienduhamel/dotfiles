{
  "permissions": {
    "allow": [
      "Bash(awk *)",
      "Bash(bat /tmp/**)",
      "Bash(bat {{ .chezmoi.homeDir }}/.config/chezmoi/**)",
      "Bash(bat {{ .chezmoi.homeDir }}/.local/share/chezmoi/**)",
      "Bash(bat --style=plain /tmp/**)",
      "Bash(bat --style=plain {{ .chezmoi.homeDir }}/.config/chezmoi/**)",
      "Bash(bat --style=plain {{ .chezmoi.homeDir }}/.local/share/chezmoi/**)",
      "Bash(cat /tmp/**)",
      "Bash(cat {{ .chezmoi.homeDir }}/.config/chezmoi/**)",
      "Bash(cat {{ .chezmoi.homeDir }}/.local/share/chezmoi/**)",
      "Bash(cd /tmp/**)",
      "Bash(cd {{ .chezmoi.homeDir }}/**)",
      "Bash(chezmoi --version)",
      "Bash(chezmoi add *)",
      "Bash(chezmoi apply *)",
      "Bash(chezmoi cat *)",
      "Bash(chezmoi diff *)",
      "Bash(chezmoi managed *)",
      "Bash(chezmoi re-add *)",
      "Bash(chezmoi source-path *)",
      "Bash(chezmoi status *)",
      "Bash(claude mcp:*)",
      "Bash(dig *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(fd *)",
      "Bash(find *)",
      "Bash(gh repo view *)",
      "Bash(git *)",
      "Bash(git check-ignore *)",
      "Bash(gitleaks *)",
      "Bash(glab *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jobs)",
      "Bash(jq *)",
      "Bash(kubectl config *)",
      "Bash(kubectl get *)",
      "Bash(ls *)",
      "Bash(npm search:*)",
      "Bash(rg *)",
      "Bash(rtk curl *)",
      "Bash(rtk diff *)",
      "Bash(rtk discover *)",
      "Bash(rtk fd *)",
      "Bash(rtk find *)",
      "Bash(rtk gain)",
      "Bash(rtk gh *)",
      "Bash(rtk git *)",
      "Bash(rtk glab *)",
      "Bash(rtk grep *)",
      "Bash(rtk helm *)",
      "Bash(rtk help *)",
      "Bash(rtk ls *)",
      "Bash(rtk read *)",
      "Bash(rtk rewrite *)",
      "Bash(rtk rg *)",
      "Bash(rtk tree *)",
      "Bash(tail *)",
      "Bash(uv --version)",
      "Bash(uv add *)",
      "Bash(uv init *)",
      "Bash(uv pip *)",
      "Bash(wc *)",
      "Bash(wget *)",
      "Bash(yq *)",
      "Edit({{ .chezmoi.homeDir }}/.claude/**)",
      "Edit({{ .chezmoi.homeDir }}/.config/chezmoi/**)",
      "Edit({{ .chezmoi.homeDir }}/.local/share/chezmoi/**)",
      "Read(//tmp/**)",
      "Read(/{{ .chezmoi.homeDir }}/.local/share/chezmoi/**)",
      "Read(/{{ .chezmoi.homeDir }}/.ssh/config)",
      "Skill(*)",
      "WebFetch",
      "WebSearch",
      "Write(/tmp/**)",
      "Write({{ .chezmoi.homeDir }}/.claude/**)",
      "Write({{ .chezmoi.homeDir }}/.config/chezmoi/**)",
      "Write({{ .chezmoi.homeDir }}/.local/share/chezmoi/**)"
    ],
    "ask": [
      "Bash(curl * | bash)",
      "Bash(git branch -D *)",
      "Bash(git clean -f*)",
      "Bash(git clean -fd*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(scp *)",
      "Bash(ssh *)"
    ],
    "deny": [
      "Bash(nc *)",
      "Read(**/.env*)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.ssh/**)"
    ],
    "additionalDirectories": [
      "{{ .chezmoi.homeDir }}/.claude/plans",
      "{{ .chezmoi.homeDir }}/.local/share/chezmoi"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ecc": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/ECC.git"
      }
    }
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen"
}
