# apps shortcuts
ctrl + alt + shift + cmd - c : open -a Google\ Chrome
ctrl + alt + shift + cmd - o : open -a Obsidian
ctrl + alt + shift + cmd - t : open -a WezTerm
ctrl + alt + shift + cmd - v : open -a Visual\ Studio\ Code
ctrl + alt + shift + cmd - s : open -a Slack

# focus window by direction
ctrl + alt + shift + cmd - left : ~/.config/skhd/focus_window.sh left
ctrl + alt + shift + cmd - right : ~/.config/skhd/focus_window.sh right
ctrl + alt + shift + cmd - a : ~/.config/skhd/focus_window.sh left
ctrl + alt + shift + cmd - e : ~/.config/skhd/focus_window.sh right

# toggle private DNS (MacOS)
cmd - f12 : ~/Dev/boilerplate/bash/mac-dns-switcher.sh 127.0.0.1
